# 免费文生图：注册 https://huggingface.co 后在 Settings → Access Tokens 创建 Token（勾选 Inference）
# 文生图默认 Flux Schnell / SDXL / SD1.5（/api/image）
# 图生图 /api/image/refine 仅本机 Diffusers（8010），无 Hugging Face 云端回退
# 本地图生图：pip install -r agent/requirements-img2img.txt；dev:thesis 已带 8010 服务
# LOCAL_IMG2IMG_URL=http://127.0.0.1:8010
# LOCAL_IMG2IMG_MODEL=runwayml/stable-diffusion-v1-5
# 若 Hub 缓存报 Operation not permitted：服务已默认用 agent/.hf_hub_cache；也可手动指定可写目录
# HF_HOME=/path/to/writable/hf_cache
HUGGINGFACE_TOKEN="hf_xxxx"

# 若无法直连 Hugging Face（ECONNRESET/超时），设置代理后重启生图服务。示例：Clash 默认 http://127.0.0.1:7890
# HF_PROXY="http://127.0.0.1:7890"

# 本地 Diffusers（8010）请求超时：首次下模型很慢，默认 600000（10 分钟），上限 1200000
# LOCAL_IMG2IMG_TIMEOUT_MS=900000
# image-server 等待 8010 时，每隔多少毫秒打一行日志（默认 10000）
# IMG2IMG_WAIT_LOG_MS=10000

# Gemini（免费额度）：https://aistudio.google.com 获取 AIza 开头
# LangGraph 文本推理默认：若未配置 LLM_* / DOUBAO_*，会自动用 GEMINI_API_KEY（免费）
GEMINI_API_KEY=""
# GEMINI_AGENT_MODEL="gemini-2.0-flash"
# 文本推理后端：ollama（本机零 Key）| gemini | openai（含豆包方舟）
# AGENT_LLM_PROVIDER="ollama"
# OLLAMA_MODEL="llama3.2"
# OLLAMA_BASE_URL="http://127.0.0.1:11434"

# 豆包（火山方舟）：在控制台创建 API Key + 推理接入点，DOUBAO_MODEL 填接入点 ID（ep- 开头）
# https://console.volcengine.com/ark/region:ark+cn-beijing/endpoint
# DOUBAO_API_KEY=""
# DOUBAO_MODEL=""

# APP_URL: 本地开发可留空或填 http://localhost:3000
APP_URL="http://localhost:3000"

# --- LangGraph Agent（npm run dev:thesis）大模型：可与豆包共用方舟 Key / 接入点 ---
# LLM_API_KEY=""
# LLM_BASE_URL="https://ark.cn-beijing.volces.com/api/v3"
# LLM_MODEL=""
# 不配 LLM_* 时，agent 会尝试使用上面的 DOUBAO_API_KEY + DOUBAO_MODEL
# AGENT_COMPRESS_AFTER=10
# AGENT_KEEP_RECENT=4
